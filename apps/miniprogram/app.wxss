page {
  min-height: 100%;
  background: #f5f7fb;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  padding: 24rpx;
}

.card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  background: #fff;
}

.muted {
  color: #6b7280;
}

.primary-button {
  background: #2563eb;
  color: #fff;
}

.ghost-button {
  background: #fff;
  color: #2563eb;
  border: 1rpx solid #bfdbfe;
}

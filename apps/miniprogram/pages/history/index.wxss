.quote-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.quote-card {
  padding: 28rpx;
}

.quote-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.quote-no {
  color: var(--text-color);
  font-size: 30rpx;
  font-weight: 700;
}

.quote-price {
  color: var(--accent-strong);
  font-size: 34rpx;
  font-weight: 800;
  white-space: nowrap;
}

.quote-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
  color: var(--text-muted);
  font-size: 24rpx;
}

.requirement-panel {
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--line-color);
}

.requirement-title {
  margin-bottom: 14rpx;
  color: var(--text-color);
  font-size: 28rpx;
  font-weight: 800;
}

.requirement-list {
  display: grid;
  gap: 12rpx;
}

.requirement-item {
  display: grid;
  gap: 6rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid var(--line-color);
  border-radius: 16rpx;
  background: var(--card-bg);
  color: var(--text-color);
  font-size: 24rpx;
}

.fee-note {
  margin-top: 20rpx;
  padding: 20rpx;
  border: 1rpx solid var(--line-color);
  border-radius: 16rpx;
  background: var(--card-bg);
}

.fee-note-title {
  margin-bottom: 12rpx;
  color: var(--text-color);
  font-weight: 700;
}

.fee-note-item {
  display: grid;
  gap: 4rpx;
  padding-top: 12rpx;
  color: var(--text-color);
  font-size: 26rpx;
}

.fee-note-item + .fee-note-item {
  border-top: 1rpx solid var(--line-color);
}

.fee-note-item text {
  color: var(--text-muted);
  font-size: 24rpx;
  line-height: 1.6;
}

.empty {
  padding: 48rpx 32rpx;
  text-align: center;
}

.empty-title {
  color: var(--text-color);
  font-size: 32rpx;
  font-weight: 700;
}

.empty-button {
  margin-top: 32rpx;
}

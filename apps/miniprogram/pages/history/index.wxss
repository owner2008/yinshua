.quote-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.quote-card {
  padding: 28rpx;
}

.quote-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.quote-no {
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
}

.quote-price {
  color: #2563eb;
  font-size: 34rpx;
  font-weight: 800;
  white-space: nowrap;
}

.quote-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
  color: #4b5563;
  font-size: 24rpx;
}

.empty {
  padding: 48rpx 32rpx;
  text-align: center;
}

.empty-title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-button {
  margin-top: 32rpx;
}

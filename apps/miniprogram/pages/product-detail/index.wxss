.hero {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.hero-thumb {
  width: 180rpx;
  height: 140rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-color);
  font-weight: 800;
  background: var(--thumb-tone-0);
}

.hero-thumb.cover {
  display: block;
  background: var(--surface-color);
}

.hero-thumb.tone-1 {
  background: var(--thumb-tone-1);
}

.hero-thumb.tone-2 {
  background: var(--thumb-tone-2);
}

.hero-body {
  flex: 1;
}

.hero-body .title {
  margin: 8rpx 0;
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-color);
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.gallery {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.gallery-img {
  width: 100%;
  height: 180rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--line-color);
}

.template-item {
  margin-bottom: 16rpx;
  padding: 16rpx;
  border: 1rpx solid var(--line-color);
  border-radius: 18rpx;
  background: var(--card-bg);
}

.template-name {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  color: var(--text-color);
}

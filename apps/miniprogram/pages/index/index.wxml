<view class="page">
  <view class="hero card" style="{{banners[0] && banners[0].imageUrl ? 'background-image: linear-gradient(135deg, rgba(17,52,72,0.88), rgba(31,111,166,0.55)), url(' + banners[0].imageUrl + '); background-size: cover; background-position: center;' : ''}}">
    <view class="hero-main">
      <view class="brand-row" wx:if="{{branding && branding.logoImage}}">
        <image class="brand-logo" src="{{branding.logoImage}}" mode="aspectFill" />
        <view>
          <text class="eyebrow">{{branding.siteSubtitle || '不干胶印刷解决方案'}}</text>
          <view class="title">{{branding.siteName || '产品展示与在线报价'}}</view>
        </view>
      </view>
      <view wx:else>
        <text class="eyebrow">不干胶印刷</text>
        <view class="title">产品展示与在线报价</view>
      </view>
      <view class="hero-copy">{{banners[0].title || '首页 Banner 已支持后台配置'}}</view>
      <view class="muted">{{banners[0].subtitle || notice}}</view>
    </view>
    <button class="primary-button" size="mini" bindtap="openBanner" data-link-type="{{banners[0].linkType}}" data-link-value="{{banners[0].linkValue}}">
      {{banners[0].buttonText || '浏览产品'}}
    </button>
  </view>

  <view class="card" wx:if="{{banners.length > 1}}">
    <view class="section-title">
      <text>首页 Banner</text>
      <text class="muted">{{banners.length}} 组内容</text>
    </view>
    <swiper class="banner-swiper" indicator-dots circular autoplay interval="4500">
      <block wx:for="{{banners}}" wx:key="id">
        <swiper-item wx:if="{{index > 0}}">
          <view class="banner-item" bindtap="openBanner" data-link-type="{{item.linkType}}" data-link-value="{{item.linkValue}}">
            <image class="banner-image" src="{{item.imageUrl}}" mode="aspectFill" />
            <view class="banner-mask">
              <view class="banner-title">{{item.title}}</view>
              <view class="banner-subtitle">{{item.subtitle || '支持后台配置标题、副标题和跳转信息'}}</view>
            </view>
          </view>
        </swiper-item>
      </block>
    </swiper>
  </view>

  <view class="card">
    <view class="section-title">
      <text>产品分类</text>
      <text class="link" bindtap="openAllProducts">全部</text>
    </view>
    <view class="chip-row">
      <block wx:for="{{categories}}" wx:key="id">
        <view class="chip" data-id="{{item.id}}" bindtap="openCategory">{{item.name}}</view>
      </block>
    </view>
  </view>

  <view class="card" wx:if="{{companyProfile}}">
    <view class="section-title">
      <text>{{companyProfile.title}}</text>
      <text class="muted">{{companyProfile.subtitle || '企业介绍'}}</text>
    </view>
    <image wx:if="{{companyProfile.coverImage}}" class="company-cover" src="{{companyProfile.coverImage}}" mode="aspectFill" />
    <view class="company-copy">{{companyProfile.content || '支持后台维护企业介绍图文内容。'}}</view>
    <view class="company-contact">
      <view wx:if="{{companyProfile.contactPhone}}">电话：{{companyProfile.contactPhone}}</view>
      <view wx:if="{{companyProfile.contactWechat}}">微信：{{companyProfile.contactWechat}}</view>
      <view wx:if="{{companyProfile.address}}">地址：{{companyProfile.address}}</view>
    </view>
    <scroll-view wx:if="{{companyProfile.galleryJson && companyProfile.galleryJson.length}}" scroll-x class="gallery-scroll">
      <view class="gallery-row">
        <block wx:for="{{companyProfile.galleryJson}}" wx:key="*this">
          <image class="gallery-thumb" src="{{item}}" mode="aspectFill" />
        </block>
      </view>
    </scroll-view>
  </view>

  <view class="card" wx:if="{{equipmentShowcases.length}}">
    <view class="section-title">
      <text>分类设备展示</text>
      <text class="muted">{{equipmentShowcases.length}} 台设备</text>
    </view>
    <view class="showcase-list">
      <block wx:for="{{equipmentShowcases}}" wx:key="id">
        <view class="showcase-item">
          <image wx:if="{{item.imageUrl}}" class="showcase-image" src="{{item.imageUrl}}" mode="aspectFill" />
          <view wx:else class="showcase-image showcase-fallback"></view>
          <view class="showcase-body">
            <view class="showcase-tag">{{item.category && item.category.name ? item.category.name : '设备展示'}}</view>
            <view class="showcase-title">{{item.title || item.name}}</view>
            <view class="showcase-desc">{{item.description || '支持后台维护设备主图、文本说明与参数信息。'}}</view>
            <view class="spec-list" wx:if="{{item.specsEntries && item.specsEntries.length}}">
              <block wx:for="{{item.specsEntries}}" wx:key="key">
                <view class="spec-item">
                  <text class="muted">{{item.key}}</text>
                  <text>{{item.value}}</text>
                </view>
              </block>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="card">
    <view class="section-title">
      <text>热门产品</text>
      <text class="muted">{{hotProducts.length}} 款</text>
    </view>
    <view class="product-grid">
      <block wx:for="{{hotProducts}}" wx:key="id">
        <view class="product-tile" data-id="{{item.id}}" bindtap="openDetail">
          <image wx:if="{{item.coverImage}}" class="tile-thumb cover" src="{{item.coverImage}}" mode="aspectFill" lazy-load="true" />
          <view wx:else class="tile-thumb tone-{{index % 3}}"></view>
          <view class="tile-name">{{item.name}}</view>
          <view class="tile-meta muted">{{item.applicationScenario || '可按需定制'}}</view>
        </view>
      </block>
    </view>
  </view>

  <view class="card">
    <view class="section-title">
      <text>最新上架</text>
      <text class="link" bindtap="openAllProducts">全部</text>
    </view>
    <view class="product-grid">
      <block wx:for="{{latestProducts}}" wx:key="id">
        <view class="product-tile" data-id="{{item.id}}" bindtap="openDetail">
          <image wx:if="{{item.coverImage}}" class="tile-thumb cover" src="{{item.coverImage}}" mode="aspectFill" lazy-load="true" />
          <view wx:else class="tile-thumb tone-{{index % 3}}"></view>
          <view class="tile-name">{{item.name}}</view>
          <view class="tile-meta muted">{{item.applicationScenario || '可按需定制'}}</view>
        </view>
      </block>
    </view>
  </view>
</view>

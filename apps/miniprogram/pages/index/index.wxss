.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  background: linear-gradient(135deg, #153448 0%, #1f6fa6 100%);
  color: #f2f7fa;
}

.hero .eyebrow {
  color: #d8e7f0;
  font-size: 22rpx;
  font-weight: 700;
}

.hero .title {
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 800;
}

.hero .muted {
  color: #c6d7de;
  margin-top: 10rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.section-title .link {
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 700;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  padding: 10rpx 22rpx;
  border: 1rpx solid #bfd1d9;
  border-radius: 999rpx;
  background: #f6fafb;
  color: #24495b;
  font-size: 26rpx;
}

.product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.product-tile {
  padding: 16rpx;
  border: 1rpx solid #d7e3e8;
  border-radius: 14rpx;
  background: #fff;
}

.tile-thumb {
  width: 100%;
  height: 140rpx;
  border-radius: 10rpx;
  background: linear-gradient(135deg, rgba(255,255,255,0.72), rgba(255,255,255,0) 45%), #83b7c8;
  margin-bottom: 12rpx;
}

.tile-thumb.cover {
  display: block;
  background: #eef3f6;
}

.tile-thumb.tone-1 {
  background: linear-gradient(135deg, rgba(255,255,255,0.72), rgba(255,255,255,0) 45%), #c4b374;
}

.tile-thumb.tone-2 {
  background: linear-gradient(135deg, rgba(255,255,255,0.72), rgba(255,255,255,0) 45%), #9bb6a6;
}

.tile-name {
  font-size: 28rpx;
  font-weight: 700;
}

.tile-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
}

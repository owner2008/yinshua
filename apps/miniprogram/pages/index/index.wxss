.hero {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  background: linear-gradient(135deg, #153448 0%, #1f6fa6 100%);
  color: #f2f7fa;
}

.hero-main {
  flex: 1;
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.brand-logo {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  background: #fff;
}

.hero .eyebrow {
  color: #d8e7f0;
  font-size: 22rpx;
  font-weight: 700;
}

.hero .title {
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 800;
}

.hero-copy {
  margin-top: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
}

.hero .muted {
  color: #d5e5ee;
  margin-top: 12rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.section-title .link {
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 700;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  padding: 10rpx 22rpx;
  border: 1rpx solid #bfd1d9;
  border-radius: 999rpx;
  background: #f6fafb;
  color: #24495b;
  font-size: 26rpx;
}

.banner-swiper {
  height: 280rpx;
}

.banner-item {
  position: relative;
  overflow: hidden;
  height: 100%;
  border-radius: 18rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-mask {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  gap: 8rpx;
  padding: 24rpx;
  background: linear-gradient(180deg, rgba(10, 20, 30, 0.08), rgba(8, 22, 31, 0.72));
  color: #fff;
}

.banner-title {
  font-size: 32rpx;
  font-weight: 800;
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
}

.company-cover {
  width: 100%;
  height: 280rpx;
  margin-bottom: 18rpx;
  border-radius: 18rpx;
}

.company-copy {
  line-height: 1.8;
  color: #29485a;
}

.company-contact {
  display: grid;
  gap: 8rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #f6fafb;
  color: #36596d;
  font-size: 24rpx;
}

.gallery-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.gallery-row {
  display: inline-flex;
  gap: 12rpx;
}

.gallery-thumb {
  width: 220rpx;
  height: 140rpx;
  border-radius: 16rpx;
  border: 1rpx solid #d7e3e8;
}

.showcase-list {
  display: grid;
  gap: 16rpx;
}

.showcase-item {
  overflow: hidden;
  border: 1rpx solid #d7e3e8;
  border-radius: 18rpx;
  background: #fbfdfe;
}

.showcase-image {
  width: 100%;
  height: 220rpx;
  background: #eef3f6;
}

.showcase-fallback {
  background: linear-gradient(135deg, #214d67, #78b6d0);
}

.showcase-body {
  display: grid;
  gap: 10rpx;
  padding: 20rpx;
}

.showcase-tag {
  color: #2a6986;
  font-size: 22rpx;
  font-weight: 700;
}

.showcase-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #163547;
}

.showcase-desc {
  color: #526c7c;
  line-height: 1.7;
}

.spec-list {
  display: grid;
  gap: 8rpx;
  margin-top: 4rpx;
}

.spec-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid #e5edf1;
  font-size: 24rpx;
}

.product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.product-tile {
  padding: 16rpx;
  border: 1rpx solid #d7e3e8;
  border-radius: 14rpx;
  background: #fff;
}

.tile-thumb {
  width: 100%;
  height: 140rpx;
  border-radius: 10rpx;
  background: linear-gradient(135deg, rgba(255,255,255,0.72), rgba(255,255,255,0) 45%), #83b7c8;
  margin-bottom: 12rpx;
}

.tile-thumb.cover {
  display: block;
  background: #eef3f6;
}

.tile-thumb.tone-1 {
  background: linear-gradient(135deg, rgba(255,255,255,0.72), rgba(255,255,255,0) 45%), #c4b374;
}

.tile-thumb.tone-2 {
  background: linear-gradient(135deg, rgba(255,255,255,0.72), rgba(255,255,255,0) 45%), #9bb6a6;
}

.tile-name {
  font-size: 28rpx;
  font-weight: 700;
}

.tile-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
}

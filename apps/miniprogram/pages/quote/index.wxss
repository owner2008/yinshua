.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.title {
  margin: 8rpx 0;
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-color);
}

.product-scroll {
  white-space: nowrap;
}

.product-chip {
  display: inline-block;
  width: 260rpx;
  margin-right: 16rpx;
  padding: 22rpx;
  vertical-align: top;
}

.product-name {
  color: var(--text-color);
  font-weight: 700;
}

.product-code {
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 24rpx;
  white-space: normal;
}

.form-card {
  padding-bottom: 12rpx;
}

.process-chip {
  padding: 12rpx 18rpx;
  font-size: 24rpx;
}

.price {
  margin: 12rpx 0;
  color: var(--text-color);
  font-size: 52rpx;
  font-weight: 800;
}

.result-card {
  padding-bottom: 16rpx;
}

.result-row {
  display: flex;
  justify-content: space-between;
  padding-top: 16rpx;
  color: var(--text-muted);
  border-top: 1rpx solid var(--line-color);
}

.fee-note {
  margin-top: 20rpx;
  padding: 20rpx;
  border: 1rpx solid var(--line-color);
  border-radius: 16rpx;
  background: var(--card-bg);
}

.fee-note-title {
  margin-bottom: 12rpx;
  color: var(--text-color);
  font-weight: 700;
}

.fee-note-item {
  display: grid;
  gap: 4rpx;
  padding-top: 12rpx;
  color: var(--text-color);
  font-size: 26rpx;
}

.fee-note-item + .fee-note-item {
  border-top: 1rpx solid var(--line-color);
}

.fee-note-item text {
  color: var(--text-muted);
  font-size: 24rpx;
  line-height: 1.6;
}

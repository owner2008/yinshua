.header-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.header-card .title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-color);
}

.header-card .action-row {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.notice {
  margin-top: 8rpx;
  color: var(--accent-color);
  font-size: 24rpx;
}

.address-item {
  margin-bottom: 12rpx;
  padding: 16rpx;
  border: 1rpx solid var(--line-color);
  border-radius: 18rpx;
  background: var(--card-bg);
}

.address-title {
  display: flex;
  gap: 10rpx;
  align-items: center;
  font-weight: 700;
  color: var(--text-color);
}

.hint {
  margin-top: 6rpx;
  font-size: 20rpx;
}

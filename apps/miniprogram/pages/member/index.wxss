.header-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.header-card .title {
  font-size: 36rpx;
  font-weight: 800;
}

.header-card .action-row {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.notice {
  margin-top: 6rpx;
  color: #2563eb;
  font-size: 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 14rpx;
}

.field > text,
.field label > text {
  color: #526c7c;
  font-size: 24rpx;
  font-weight: 700;
}

.field input,
.picker-value {
  padding: 16rpx 18rpx;
  border: 1rpx solid #c9d8df;
  border-radius: 12rpx;
  background: #fbfdfe;
}

.field.two {
  flex-direction: row;
  gap: 16rpx;
}

.field.two label {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
  color: #344d5d;
  font-weight: 700;
}

.address-item {
  margin-bottom: 12rpx;
  padding: 14rpx;
  border: 1rpx solid #d7e3e8;
  border-radius: 12rpx;
  background: #f8fbfc;
}

.address-title {
  display: flex;
  gap: 10rpx;
  align-items: center;
  font-weight: 700;
}

.badge {
  margin-left: 10rpx;
  padding: 2rpx 14rpx;
  font-size: 22rpx;
  border-radius: 999rpx;
  background: #f4b400;
  color: #1a2940;
}

.hint {
  margin-top: 6rpx;
  font-size: 20rpx;
}
